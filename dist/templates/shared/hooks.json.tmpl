{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "find docs/rules -type f 2>/dev/null | sort | sed 's/^/Read file: /'",
            "commandWindows": "if (Test-Path docs/rules) { Get-ChildItem -Recurse -File docs/rules | Sort-Object FullName | ForEach-Object { 'Read file: ' + $_.FullName.Substring($PWD.Path.Length + 1).Replace([char]92,'/') } }",
            "timeout": 10,
            "statusMessage": "Loading project rules"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "in=$(cat); if printf '%s' \"$in\" | grep -Eq 'git[^A-Za-z]{1,4}commit'; then printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Before committing: read the AUDIT procedure in the rule files under docs/rules/ and confirm all steps have been completed.\"}}'; fi",
            "commandWindows": "$in = [Console]::In.ReadToEnd(); if ($in -match 'git[^A-Za-z]{1,4}commit') { '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Before committing: read the AUDIT procedure in the rule files under docs/rules/ and confirm all steps have been completed.\"}}' }",
            "timeout": 10,
            "statusMessage": "Audit reminder"
          }
        ]
      }
    ]
  }
}
