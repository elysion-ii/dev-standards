{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s\\n\\n' 'MANDATORY: Before you answer, plan, or run any other tool this session, read EVERY file below IN FULL using your file-reading tool. Do not do anything else until all are read:'; find docs/rules -type f 2>/dev/null | sort",
            "statusMessage": "Loading project rules"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'grep -q \"audit\\.ok=true\" && exit 0 || printf \"%s\" \"$0\"' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"AUDIT not confirmed. Run the AUDIT procedure in docs/rules and fix issues; if already complete, re-run with: git -c audit.ok=true commit\"}}'",
            "if": "Bash(git commit*)",
            "statusMessage": "Audit gate"
          }
        ]
      }
    ]
  }
}
