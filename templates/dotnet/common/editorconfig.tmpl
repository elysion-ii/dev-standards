# Shared code style for editors and `dotnet format`.
# Rule IDs in comments refer to docs/rules/dotnet.md.
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# XML-based project files follow the 2-space convention
[*.{csproj,slnx,props,targets,resx,xml}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
# Trailing double-space is a hard line break in Markdown
trim_trailing_whitespace = false

[*.cs]
# NAMESPACE: file-scoped namespaces only
csharp_style_namespace_declarations = file_scoped:warning

# VAR: var when the type is apparent from the right-hand side, explicit otherwise
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_elsewhere = false:suggestion

# Usings: outside namespace, System directives first
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
